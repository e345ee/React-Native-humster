{
  "name": "stock-exchange-rn",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start --clear",
    "android": "expo start --android",
    "android:tunnel": "expo start --android --tunnel",
    "ios": "expo start --ios",
    "lint": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "native:android": "npm run prebuild:android && expo run:android",
    "native:ios": "expo prebuild --platform ios --clean && expo run:ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.8.4",
    "expo": "~51.0.28",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-svg": "15.2.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.2.79",
    "babel-preset-expo": "^11.0.10",
    "typescript": "^5.3.3",
    "@types/node": "^22.15.3",
    "expo-doctor": "^1.18.17"
  }
}
